<?xml version="1.0" encoding="UTF-8"?>
<mule xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:munit="http://www.mulesoft.org/schema/mule/munit"
	xmlns:munit-tools="http://www.mulesoft.org/schema/mule/munit-tools"
	xmlns="http://www.mulesoft.org/schema/mule/core"
	xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
	xsi:schemaLocation="
		http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
		http://www.mulesoft.org/schema/mule/munit http://www.mulesoft.org/schema/mule/munit/current/mule-munit.xsd
		http://www.mulesoft.org/schema/mule/munit-tools http://www.mulesoft.org/schema/mule/munit-tools/current/mule-munit-tools.xsd">

	<munit:config name="rides-test" />

	<!-- POST /rides — Create ride -->
	<munit:test name="post-rides-test" description="Test POST /rides - creates a new ride">
		<munit:behavior>
			<munit-tools:mock-when doc:name="Mock DB insert" processor="db:insert">
				<munit-tools:then-return>
					<munit-tools:payload value='#[[{"ride_id": "44e128a5-ac7a-4c9a-be4c-224b6bf81b20", "status": "NEW", "created_at": "2024-01-01"}]]' />
				</munit-tools:then-return>
			</munit-tools:mock-when>
		</munit:behavior>
		<munit:execution>
			<munit:set-event doc:name="Set Request Payload">
				<munit:payload value='#[{"pickupLocation": "123456,523543425", "destination": "1321,235352", "destinationName": "Cumaica Artesanos del Cafe"}]' mediaType="application/json" />
				<munit:attributes value="#[{headers: {}, uriParams: {}}]" />
			</munit:set-event>
			<flow-ref name="post:\rides:router" doc:name="Call post:\rides:router" />
		</munit:execution>
		<munit:validation>
			<munit-tools:assert-that doc:name="Assert 201 status" expression="#[vars.httpStatus]" is="#[MunitTools::equalTo('201')]" />
		</munit:validation>
	</munit:test>

	<!-- GET /ride/{id} — Get ride by ID -->
	<munit:test name="get-ride-by-id-test" description="Test GET /ride/{id} - retrieves ride by ID">
		<munit:behavior>
			<munit-tools:mock-when doc:name="Mock DB select" processor="db:select">
				<munit-tools:then-return>
					<munit-tools:payload value='#[[{"ride_id": "44e128a5-ac7a-4c9a-be4c-224b6bf81b20", "user_id": "e58ed763-928c-4155-bee9-fdbaaadc15f3", "driver_id": null, "status": "NEW", "rate": 27.86, "pickup_location": "123,456", "destination": "789,012", "destination_name": "Test", "start_location": null, "end_location": null, "created_at": "2024-01-01", "updated_at": "2024-01-01"}]]' />
				</munit-tools:then-return>
			</munit-tools:mock-when>
		</munit:behavior>
		<munit:execution>
			<munit:set-event doc:name="Set Event">
				<munit:attributes value="#[{headers: {}, uriParams: {id: '44e128a5-ac7a-4c9a-be4c-224b6bf81b20'}}]" />
			</munit:set-event>
			<flow-ref name="get:\ride\(id):router" doc:name="Call get:\ride\(id):router" />
		</munit:execution>
		<munit:validation>
			<munit-tools:assert-that doc:name="Assert payload not null" expression="#[payload]" is="#[MunitTools::notNullValue()]" />
		</munit:validation>
	</munit:test>

	<!-- GET /ride/{id} — Ride not found -->
	<munit:test name="get-ride-by-id-not-found-test" description="Test GET /ride/{id} - returns 404 when ride not found">
		<munit:behavior>
			<munit-tools:mock-when doc:name="Mock DB select empty" processor="db:select">
				<munit-tools:then-return>
					<munit-tools:payload value="#[[]]" />
				</munit-tools:then-return>
			</munit-tools:mock-when>
		</munit:behavior>
		<munit:execution>
			<munit:set-event doc:name="Set Event">
				<munit:attributes value="#[{headers: {}, uriParams: {id: '00000000-0000-0000-0000-000000000000'}}]" />
			</munit:set-event>
			<flow-ref name="get:\ride\(id):router" doc:name="Call get:\ride\(id):router" />
		</munit:execution>
		<munit:validation>
			<munit-tools:assert-that doc:name="Assert 404 status" expression="#[vars.httpStatus]" is="#[MunitTools::equalTo('404')]" />
		</munit:validation>
	</munit:test>

	<!-- PATCH /ride/{id} — Update ride -->
	<munit:test name="patch-ride-by-id-test" description="Test PATCH /ride/{id} - updates ride status">
		<munit:behavior>
			<munit-tools:mock-when doc:name="Mock DB update" processor="db:update">
				<munit-tools:then-return>
					<munit-tools:payload value="#[1]" />
				</munit-tools:then-return>
			</munit-tools:mock-when>
		</munit:behavior>
		<munit:execution>
			<munit:set-event doc:name="Set Request Payload">
				<munit:payload value='#[{"status": "ACCEPTED_BY_DRIVER", "driverId": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"}]' mediaType="application/json" />
				<munit:attributes value="#[{headers: {}, uriParams: {id: '44e128a5-ac7a-4c9a-be4c-224b6bf81b20'}}]" />
			</munit:set-event>
			<flow-ref name="patch:\ride\(id):router" doc:name="Call patch:\ride\(id):router" />
		</munit:execution>
		<munit:validation>
			<munit-tools:assert-that doc:name="Assert payload not null" expression="#[payload]" is="#[MunitTools::notNullValue()]" />
		</munit:validation>
	</munit:test>

	<!-- POST /ride/{id}/feedback — Submit ride feedback -->
	<munit:test name="post-ride-feedback-test" description="Test POST /ride/{id}/feedback - submits ride feedback">
		<munit:behavior>
			<munit-tools:mock-when doc:name="Mock DB insert" processor="db:insert">
				<munit-tools:then-return>
					<munit-tools:payload value="#[1]" />
				</munit-tools:then-return>
			</munit-tools:mock-when>
		</munit:behavior>
		<munit:execution>
			<munit:set-event doc:name="Set Request Payload">
				<munit:payload value='#[{"rating": "5", "userId": "e58ed763-928c-4155-bee9-fdbaaadc15f3"}]' mediaType="application/json" />
				<munit:attributes value="#[{headers: {}, uriParams: {id: '44e128a5-ac7a-4c9a-be4c-224b6bf81b20'}}]" />
			</munit:set-event>
			<flow-ref name="post:\ride\(id)\feedback:router" doc:name="Call post:\ride\(id)\feedback:router" />
		</munit:execution>
		<munit:validation>
			<munit-tools:assert-that doc:name="Assert 201 status" expression="#[vars.httpStatus]" is="#[MunitTools::equalTo('201')]" />
		</munit:validation>
	</munit:test>

</mule>
