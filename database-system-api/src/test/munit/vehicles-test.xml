<?xml version="1.0" encoding="UTF-8"?>
<mule xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:munit="http://www.mulesoft.org/schema/mule/munit"
	xmlns:munit-tools="http://www.mulesoft.org/schema/mule/munit-tools"
	xmlns="http://www.mulesoft.org/schema/mule/core"
	xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
	xsi:schemaLocation="
		http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
		http://www.mulesoft.org/schema/mule/munit http://www.mulesoft.org/schema/mule/munit/current/mule-munit.xsd
		http://www.mulesoft.org/schema/mule/munit-tools http://www.mulesoft.org/schema/mule/munit-tools/current/mule-munit-tools.xsd">

	<munit:config name="vehicles-test" />

	<!-- GET /users/{id}/vehicles — Get user vehicles -->
	<munit:test name="get-user-vehicles-test" description="Test GET /users/{id}/vehicles - retrieves user vehicles">
		<munit:behavior>
			<munit-tools:mock-when doc:name="Mock DB select" processor="db:select">
				<munit-tools:then-return>
					<munit-tools:payload value='#[[{"vehicle_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890", "user_id": "e58ed763-928c-4155-bee9-fdbaaadc15f3", "make": "Ford", "model": "Focus", "year": 2012, "license_plate": "8PSQ3456", "insurance_policy": "ABC123456", "is_active": true, "created_at": "2024-01-01", "updated_at": "2024-01-01"}]]' />
				</munit-tools:then-return>
			</munit-tools:mock-when>
		</munit:behavior>
		<munit:execution>
			<munit:set-event doc:name="Set Event">
				<munit:attributes value="#[{headers: {}, uriParams: {id: 'e58ed763-928c-4155-bee9-fdbaaadc15f3'}}]" />
			</munit:set-event>
			<flow-ref name="get:\users\(id)\vehicles:router" doc:name="Call get:\users\(id)\vehicles:router" />
		</munit:execution>
		<munit:validation>
			<munit-tools:assert-that doc:name="Assert payload not null" expression="#[payload]" is="#[MunitTools::notNullValue()]" />
		</munit:validation>
	</munit:test>

	<!-- POST /users/{id}/vehicles — Add vehicle -->
	<munit:test name="post-user-vehicles-test" description="Test POST /users/{id}/vehicles - adds a vehicle">
		<munit:behavior>
			<munit-tools:mock-when doc:name="Mock DB insert" processor="db:insert">
				<munit-tools:then-return>
					<munit-tools:payload value="#[1]" />
				</munit-tools:then-return>
			</munit-tools:mock-when>
		</munit:behavior>
		<munit:execution>
			<munit:set-event doc:name="Set Request Payload">
				<munit:payload value='#[{"make": "Ford", "model": "Focus", "year": 2012, "licensePlate": "8PSQ3456", "insurancePolicy": "ABC123456"}]' mediaType="application/json" />
				<munit:attributes value="#[{headers: {}, uriParams: {id: 'e58ed763-928c-4155-bee9-fdbaaadc15f3'}}]" />
			</munit:set-event>
			<flow-ref name="post:\users\(id)\vehicles:router" doc:name="Call post:\users\(id)\vehicles:router" />
		</munit:execution>
		<munit:validation>
			<munit-tools:assert-that doc:name="Assert 201 status" expression="#[vars.httpStatus]" is="#[MunitTools::equalTo('201')]" />
		</munit:validation>
	</munit:test>

	<!-- PUT /users/{id}/vehicles/{vehicleId} — Update vehicle -->
	<munit:test name="put-user-vehicles-test" description="Test PUT /users/{id}/vehicles/{vehicleId} - updates a vehicle">
		<munit:behavior>
			<munit-tools:mock-when doc:name="Mock DB update" processor="db:update">
				<munit-tools:then-return>
					<munit-tools:payload value="#[1]" />
				</munit-tools:then-return>
			</munit-tools:mock-when>
		</munit:behavior>
		<munit:execution>
			<munit:set-event doc:name="Set Request Payload">
				<munit:payload value='#[{"make": "Toyota", "model": "Camry", "isActive": true}]' mediaType="application/json" />
				<munit:attributes value="#[{headers: {}, uriParams: {id: 'e58ed763-928c-4155-bee9-fdbaaadc15f3', vehicleId: 'a1b2c3d4-e5f6-7890-abcd-ef1234567890'}}]" />
			</munit:set-event>
			<flow-ref name="put:\users\(id)\vehicles\(vehicleId):router" doc:name="Call put:\users\(id)\vehicles\(vehicleId):router" />
		</munit:execution>
		<munit:validation>
			<munit-tools:assert-that doc:name="Assert payload not null" expression="#[payload]" is="#[MunitTools::notNullValue()]" />
		</munit:validation>
	</munit:test>

</mule>
