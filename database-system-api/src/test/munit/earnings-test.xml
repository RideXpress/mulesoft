<?xml version="1.0" encoding="UTF-8"?>
<mule xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:munit="http://www.mulesoft.org/schema/mule/munit"
	xmlns:munit-tools="http://www.mulesoft.org/schema/mule/munit-tools"
	xmlns="http://www.mulesoft.org/schema/mule/core"
	xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
	xsi:schemaLocation="
		http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
		http://www.mulesoft.org/schema/mule/munit http://www.mulesoft.org/schema/mule/munit/current/mule-munit.xsd
		http://www.mulesoft.org/schema/mule/munit-tools http://www.mulesoft.org/schema/mule/munit-tools/current/mule-munit-tools.xsd">

	<munit:config name="earnings-test" />

	<!-- POST /drivers/{id}/earnings — Record earnings -->
	<munit:test name="post-driver-earnings-test" description="Test POST /drivers/{id}/earnings - records driver earnings">
		<munit:behavior>
			<munit-tools:mock-when doc:name="Mock DB insert" processor="db:insert">
				<munit-tools:then-return>
					<munit-tools:payload value="#[1]" />
				</munit-tools:then-return>
			</munit-tools:mock-when>
		</munit:behavior>
		<munit:execution>
			<munit:set-event doc:name="Set Request Payload">
				<munit:payload value='#[{"rideId": "44e128a5-ac7a-4c9a-be4c-224b6bf81b20", "grossFare": 25.00, "platformCommission": 5.00, "netEarnings": 20.00}]' mediaType="application/json" />
				<munit:attributes value="#[{headers: {}, uriParams: {id: 'e58ed763-928c-4155-bee9-fdbaaadc15f3'}}]" />
			</munit:set-event>
			<flow-ref name="post:\drivers\(id)\earnings:router" doc:name="Call post:\drivers\(id)\earnings:router" />
		</munit:execution>
		<munit:validation>
			<munit-tools:assert-that doc:name="Assert 201 status" expression="#[vars.httpStatus]" is="#[MunitTools::equalTo('201')]" />
		</munit:validation>
	</munit:test>

	<!-- GET /drivers/{id}/earnings — Get earnings history -->
	<munit:test name="get-driver-earnings-test" description="Test GET /drivers/{id}/earnings - retrieves driver earnings">
		<munit:behavior>
			<munit-tools:mock-when doc:name="Mock DB select" processor="db:select">
				<munit-tools:then-return>
					<munit-tools:payload value='#[[{"earning_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890", "user_id": "e58ed763-928c-4155-bee9-fdbaaadc15f3", "ride_id": "44e128a5-ac7a-4c9a-be4c-224b6bf81b20", "gross_fare": 25.00, "platform_commission": 5.00, "tip_amount": 3.00, "cancellation_portion": 0.00, "deductions": 0.00, "net_earnings": 23.00, "created_at": "2024-01-01"}]]' />
				</munit-tools:then-return>
			</munit-tools:mock-when>
		</munit:behavior>
		<munit:execution>
			<munit:set-event doc:name="Set Event">
				<munit:attributes value="#[{headers: {}, uriParams: {id: 'e58ed763-928c-4155-bee9-fdbaaadc15f3'}}]" />
			</munit:set-event>
			<flow-ref name="get:\drivers\(id)\earnings:router" doc:name="Call get:\drivers\(id)\earnings:router" />
		</munit:execution>
		<munit:validation>
			<munit-tools:assert-that doc:name="Assert payload not null" expression="#[payload]" is="#[MunitTools::notNullValue()]" />
		</munit:validation>
	</munit:test>

	<!-- POST /drivers/{id}/payouts — Create payout -->
	<munit:test name="post-driver-payouts-test" description="Test POST /drivers/{id}/payouts - creates driver payout">
		<munit:behavior>
			<munit-tools:mock-when doc:name="Mock DB insert" processor="db:insert">
				<munit-tools:then-return>
					<munit-tools:payload value="#[1]" />
				</munit-tools:then-return>
			</munit-tools:mock-when>
		</munit:behavior>
		<munit:execution>
			<munit:set-event doc:name="Set Request Payload">
				<munit:payload value='#[{"amount": 250.00, "currency": "USD", "payoutPeriod": "2024-01-01"}]' mediaType="application/json" />
				<munit:attributes value="#[{headers: {}, uriParams: {id: 'e58ed763-928c-4155-bee9-fdbaaadc15f3'}}]" />
			</munit:set-event>
			<flow-ref name="post:\drivers\(id)\payouts:router" doc:name="Call post:\drivers\(id)\payouts:router" />
		</munit:execution>
		<munit:validation>
			<munit-tools:assert-that doc:name="Assert 201 status" expression="#[vars.httpStatus]" is="#[MunitTools::equalTo('201')]" />
		</munit:validation>
	</munit:test>

	<!-- PATCH /drivers/{id}/payouts/{payoutId} — Update payout status -->
	<munit:test name="patch-driver-payout-test" description="Test PATCH /drivers/{id}/payouts/{payoutId} - updates payout status">
		<munit:behavior>
			<munit-tools:mock-when doc:name="Mock DB update" processor="db:update">
				<munit-tools:then-return>
					<munit-tools:payload value="#[1]" />
				</munit-tools:then-return>
			</munit-tools:mock-when>
		</munit:behavior>
		<munit:execution>
			<munit:set-event doc:name="Set Request Payload">
				<munit:payload value='#[{"status": "completed"}]' mediaType="application/json" />
				<munit:attributes value="#[{headers: {}, uriParams: {id: 'e58ed763-928c-4155-bee9-fdbaaadc15f3', payoutId: 'a1b2c3d4-e5f6-7890-abcd-ef1234567890'}}]" />
			</munit:set-event>
			<flow-ref name="patch:\drivers\(id)\payouts\(payoutId):router" doc:name="Call patch:\drivers\(id)\payouts\(payoutId):router" />
		</munit:execution>
		<munit:validation>
			<munit-tools:assert-that doc:name="Assert payload not null" expression="#[payload]" is="#[MunitTools::notNullValue()]" />
		</munit:validation>
	</munit:test>

</mule>
