<?xml version="1.0" encoding="UTF-8"?>
<mule xmlns:http="http://www.mulesoft.org/schema/mule/http"
    xmlns:amqp="http://www.mulesoft.org/schema/mule/amqp"
    xmlns="http://www.mulesoft.org/schema/mule/core"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.mulesoft.org/schema/mule/http http://www.mulesoft.org/schema/mule/http/current/mule-http.xsd
        http://www.mulesoft.org/schema/mule/amqp http://www.mulesoft.org/schema/mule/amqp/current/mule-amqp.xsd
        http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd">

    <configuration-properties file="config.properties" />
    <configuration-properties file="${secrets.path}" />
    <amqp:config name="rabbitmq">
        <amqp:connection host="${rabbitmq.hostname}" port="${rabbitmq.port}" virtualHost="${rabbitmq.virtualhost}" username="${rabbitmq.username}" password="${rabbitmq.password}" />
    </amqp:config>
    <http:request-config name="request-ride-process-api" basePath="/api">
        <http:request-connection host="${request-ride-process-api.hostname}" port="${request-ride-process-api.port}" />
    </http:request-config>
    <http:request-config name="database-system-api" basePath="/api">
        <http:request-connection host="${database-system-api.hostname}" port="${database-system-api.port}" />
    </http:request-config>
</mule>
