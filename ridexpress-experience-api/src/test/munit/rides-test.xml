    <munit:test name="get-rides-test" description="Test GET /rides flow - mocks database-system-api GET /rides and returns rides list">
        <munit:behavior>
            <munit-tools:mock-when doc:name="Mock database-system-api GET /rides" processor="http:request">
                <munit-tools:then-return>
                    <munit-tools:payload
                        value='#[[{"ride_id": "44e128a5-ac7a-4c9a-be4c-224b6bf81b20", "user_id": "e58ed763-928c-4155-bee9-fdbaaadc15f3", "driver_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890", "status": "NEW", "start_location": "123456,523543425", "end_location": "1321,235352", "created_at": "2024-01-01", "updated_at": "2024-01-01"}]]'
                        mediaType="application/json" />
                    <munit-tools:attributes value="#[{statusCode: 200, headers: {}}]" />
                </munit-tools:then-return>
            </munit-tools:mock-when>
        </munit:behavior>
        <munit:execution>
            <munit:set-event doc:name="Set Event">
                <munit:attributes value="#[{headers: {}, queryParams: {}}]" />
            </munit:set-event>
            <flow-ref name="get:\rides:router" doc:name="Call get:\rides:router" />
        </munit:execution>
        <munit:validation>
            <munit-tools:assert-that doc:name="Assert payload not null"
                expression="#[payload]"
                is="#[MunitTools::notNullValue()]" />
        </munit:validation>
    </munit:test>

