    <munit:config name="rides-test" />

    <munit:test name="get-rides-test" description="Test GET /rides flow - mocks DB select and returns rides list">
        <munit:behavior>
            <munit-tools:mock-when doc:name="Mock DB Select Rides" processor="db:select">
                <munit-tools:then-return>
                    <munit-tools:payload
                        value="#[[{ride_id: '44e128a5-ac7a-4c9a-be4c-224b6bf81b20', user_id: 'e58ed763-928c-4155-bee9-fdbaaadc15f3', driver_id: 'a1b2c3d4-e5f6-7890-abcd-ef1234567890', status: 'NEW', start_location: '123456,523543425', end_location: '1321,235352', created_at: '2024-01-01', updated_at: '2024-01-01'}]]"
                        mediaType="application/java" />
                </munit-tools:then-return>
            </munit-tools:mock-when>
        </munit:behavior>
        <munit:execution>
            <flow-ref name="get:\rides:router" doc:name="Call get:\rides:router" />
        </munit:execution>
        <munit:validation>
            <munit-tools:assert-that doc:name="Assert payload not null"
                expression="#[payload]"
                is="#[MunitTools::notNullValue()]" />
        </munit:validation>
    </munit:test>

    <munit:test name="post-rides-test" description="Test POST /rides flow - mocks AMQP publish">
        <munit:behavior>
            <munit-tools:set-event doc:name="Set Request Payload">
                <munit-tools:payload
                    value='#[{"pickupLocation": "123456,523543425", "destination": "1321,235352", "destinationName": "Cumaica Artesanos del Cafe"}]'
                    mediaType="application/json" />
            </munit-tools:set-event>
            <munit-tools:mock-when doc:name="Mock AMQP Publish" processor="amqp:publish">
                <munit-tools:then-return />
            </munit-tools:mock-when>
        </munit:behavior>
        <munit:execution>
            <flow-ref name="post:\rides:router" doc:name="Call post:\rides:router" />
        </munit:execution>
        <munit:validation>
            <munit-tools:assert-that doc:name="Assert payload not null"
                expression="#[payload]"
                is="#[MunitTools::notNullValue()]" />
        </munit:validation>
    </munit:test>

    <munit:test name="get-rides-id-test" description="Test GET /rides/{id} flow - verifies id variable is set from URI params">
        <munit:behavior>
            <munit-tools:set-event doc:name="Set Event">
                <munit-tools:attributes
                    value="#[{uriParams: {id: '44e128a5-ac7a-4c9a-be4c-224b6bf81b20'}}]" />
            </munit-tools:set-event>
        </munit:behavior>
        <munit:execution>
            <flow-ref name="get:\rides\(id):router" doc:name="Call get:\rides\(id):router" />
        </munit:execution>
        <munit:validation>
            <munit-tools:assert-that doc:name="Assert id variable is set"
                expression="#[vars.id]"
                is="#[MunitTools::equalTo('44e128a5-ac7a-4c9a-be4c-224b6bf81b20')]" />
        </munit:validation>
    </munit:test>

